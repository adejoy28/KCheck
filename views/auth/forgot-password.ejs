<div class="login">
    <div class="login__card">
        <div class="login__brand">
            <div class="login__logo">
                <img src="/images/logo.png" alt="Globacom Logo" width="60" height="60">
            </div>
            <h3 class="login__title">Knowledge Check</h3>
            <div class="login__version">Version 1.0.0</div>
        </div>
        <div class="login__form">
            <h2 class="login__heading">Reset Password</h2>
            <form action="/auth/forgot-password" method="POST">
                <div class="login__group">
                    <label class="login__label" for="email">Email Address</label>
                    <input type="email" class="login__input" id="email" name="email" placeholder="Enter your registered email" required>
                </div>
                
                <button type="submit" class="login__button">Send Reset Link</button>
            </form>
            
            <div class="login__forgot">
                <a class="login__forgot-link" href="/auth/login">Back to Login</a>
            </div>
        </div>
    </div>
</div>
