<div class="login">
    <div class="login__card">
        <div class="login__brand">
            <div class="login__logo">
                <img src="/images/logo.png" alt="Globacom Logo" width="60" height="60">
            </div>
            <h3 class="login__title">Knowledge Check</h3>
            <div class="login__version">Version 1.0.0</div>
        </div>
        <div class="login__form">
            <h2 class="login__heading">Register</h2>
            <form action="/auth/register" method="POST">
                <div class="login__group">
                    <label class="login__label" for="name">Full Name</label>
                    <input type="text" class="login__input" id="name" name="name" required>
                </div>
                
                <div class="login__group">
                    <label class="login__label" for="username">Username</label>
                    <input type="text" class="login__input" id="username" name="username" required>
                </div>
                
                <div class="login__group">
                    <label class="login__label" for="email">Email</label>
                    <input type="email" class="login__input" id="email" name="email" required>
                </div>
                
                <div class="login__group">
                    <label class="login__label" for="password">Password</label>
                    <input type="password" class="login__input" id="password" name="password" required>
                </div>
                
                <div class="login__group">
                    <label class="login__label" for="confirmPassword">Confirm Password</label>
                    <input type="password" class="login__input" id="confirmPassword" name="confirmPassword" required>
                </div>
                
                <div class="login__group">
                    <label class="login__label" for="role">Role</label>
                    <select class="login__input" id="role" name="role" required>
                        <option value="">Select Role</option>
                        <option value="user">User</option>
                        <option value="staff">Staff</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                
                <button type="submit" class="login__button">Register</button>
            </form>
            
            <div class="login__forgot">
                <a class="login__forgot-link" href="/auth/login">Already have an account? Login</a>
            </div>
        </div>
    </div>
</div>
