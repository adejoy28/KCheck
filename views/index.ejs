    <script>
        // ── Sidebar active state ──
        const setActive = (el) => {
            document.querySelectorAll('.sidebar__item').forEach(i => i.classList.remove('sidebar__item--active'));
            el.classList.add('sidebar__item--active');
        };

        // ── Sample data (replace with real API calls) ──
        const allData = [
            // Uncomment to see data rows:
            { id: 'TST001', name: 'JavaScript Basics', category: 'Programming', questions: 20, duration: '30 min', status: 'Active', createdDate: '2024-01-15' },
            { id: 'TST002', name: 'Network Fundamentals', category: 'Networking', questions: 25, duration: '45 min', status: 'Draft', createdDate: '2024-01-16' },
        ];

        let filteredData = [...allData];

        const renderTable = (data) => {
            const tbody = document.getElementById('tableBody');
            if (data.length === 0) {
                tbody.innerHTML = `<tr class="table__empty-row"><td colspan="8">No tests to display.</td></tr>`;
                return;
            }
            tbody.innerHTML = data.map(row => `
        <tr>
          <td>${row.id}</td>
          <td>${row.name}</td>
          <td>${row.category}</td>
          <td>${row.questions}</td>
          <td>${row.duration}</td>
          <td><span class="status-badge status-${row.status.toLowerCase()}">${row.status}</span></td>
          <td>${row.createdDate}</td>
          <td>
            <button class="action-btn" onclick="editTest('${row.id}')" title="Edit">✏️</button>
            <button class="action-btn" onclick="deleteTest('${row.id}')" title="Delete">🗑️</button>
          </td>
        </tr>
      `).join('');
        };

        // ── Column filter logic ──
        const filterTable = () => {
            const filters = Array.from(document.querySelectorAll('.table__filter-input, .table__date-input'))
                .map(i => i.value.toLowerCase().trim());

            filteredData = allData.filter(row => {
                const vals = [row.id, row.name, row.category, row.questions.toString(), row.duration, row.status, row.createdDate, ''];
                return vals.every((v, i) => !filters[i] || v.toLowerCase().includes(filters[i]));
            });

            renderTable(filteredData);
        };

        // ── Test search ──
        const testSearch = () => {
            const searchTerm = document.getElementById('testSearch').value.trim();
            if (!searchTerm) {
                renderTable(allData);
                return;
            }
            const result = allData.filter(r => 
                r.name.toLowerCase().includes(searchTerm.toLowerCase()) ||
                r.id.toLowerCase().includes(searchTerm.toLowerCase())
            );
            renderTable(result);
        };

        // Enter key on search
        document.getElementById('testSearch').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') testSearch();
        });

        // ── Action functions ──
        const createNewTest = () => {
            alert('Create New Test functionality would be implemented here');
        };

        const importQuestions = () => {
            alert('Import Questions functionality would be implemented here');
        };

        const exportResults = () => {
            alert('Export Results functionality would be implemented here');
        };

        const editTest = (testId) => {
            alert(`Edit test ${testId} functionality would be implemented here`);
        };

        const deleteTest = (testId) => {
            if (confirm(`Are you sure you want to delete test ${testId}?`)) {
                alert(`Delete test ${testId} functionality would be implemented here`);
            }
        };

        // ── Logout ──
        const handleLogout = () => {
            if (confirm('Are you sure you want to logout?')) {
                window.location.href = '/auth/logout';
            }
        };

        // ── Initial render ──
        renderTable(allData);
    </script>

