<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

<body>
    <div id="wrapper">
        <%- include('partials/toast') %>

        <%- include('partials/header') %>

        <!-- Layout -->
        <div class="layout">
            <%- include('partials/sidebar') %>

            <!-- Main Content Area -->
            <div class="layout__main">
                <div class="layout__content" id="mainContent">
                    <!-- Content will be loaded here dynamically -->
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <span class="footer__text">© 2024 Globacom Knowledge Check System. All rights reserved.</span>
        </div>
    </div>

    <script src="/js/script.js"></script>
    <script>
        // Page content templates
        const pageTemplates = {
            dashboard: `
                <div class="page-header">DASHBOARD</div>
                <!-- User Info Bar -->
                <div class="user-info-bar">
                    <span class="user-info-text">User Logged In: <strong id="userInfo">Loading...</strong></span>
                    <span class="user-info-text">Status: <span class="status-active">Active</span></span>
                </div>
                <!-- Dashboard Stats Grid -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">📝</div>
                        <div class="stat-content">
                            <div class="stat-number" id="totalExams">0</div>
                            <div class="stat-label">Total Exams</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">✅</div>
                        <div class="stat-content">
                            <div class="stat-number" id="activeExams">0</div>
                            <div class="stat-label">Active Exams</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">👥</div>
                        <div class="stat-content">
                            <div class="stat-number" id="totalUsers">0</div>
                            <div class="stat-label">Total Users</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">📊</div>
                        <div class="stat-content">
                            <div class="stat-number" id="completedTests">0</div>
                            <div class="stat-label">Completed Tests</div>
                        </div>
                    </div>
                </div>
                <!-- Recent Activity -->
                <div class="dashboard-section">
                    <h3>Recent Exams</h3>
                    <div class="table__wrap">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th class="table__header">Exam Name</th>
                                    <th class="table__header">Questions</th>
                                    <th class="table__header">Duration</th>
                                    <th class="table__header">Status</th>
                                    <th class="table__header">Created Date</th>
                                </tr>
                            </thead>
                            <tbody id="recentExamsTable">
                                <tr class="table__empty-row">
                                    <td colspan="5">Loading recent exams...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- Quick Actions -->
                <div class="dashboard-section">
                    <h3>Quick Actions</h3>
                    <div class="quick-actions">
                        <button class="action-card" onclick="loadPage('tests')">
                            <div class="action-icon">➕</div>
                            <div class="action-title">Create New Exam</div>
                            <div class="action-description">Create a new knowledge check exam</div>
                        </button>
                        <button class="action-card" onclick="viewResults()">
                            <div class="action-icon">📈</div>
                            <div class="action-title">View Results</div>
                            <div class="action-description">Analyze exam performance and results</div>
                        </button>
                        <button class="action-card" onclick="manageUsers()">
                            <div class="action-icon">👥</div>
                            <div class="action-title">Manage Users</div>
                            <div class="action-description">Add or remove system users</div>
                        </button>
                    </div>
                </div>
            `,
            tests: `
                <div class="page-header">NEW TESTS</div>
                <!-- User Info Bar -->
                <div class="user-info-bar">
                    <span class="user-info-text">User Logged In: <strong id="userInfo">Loading...</strong></span>
                    <span class="user-info-text">Status: <span class="status-active">Active</span></span>
                </div>
                <!-- Toolbar -->
                <div class="toolbar">
                    <button class="toolbar__button" onclick="createNewTest()">
                        <span class="btn-icon">➕</span> Create New Test
                    </button>
                    <button class="toolbar__button" onclick="importQuestions()">
                        <span class="btn-icon">📥</span> Import Questions
                    </button>
                    <button class="toolbar__button" onclick="exportResults()">
                        <span class="btn-icon">📤</span> Export Results
                    </button>
                    <input class="toolbar__search" type="text" placeholder="Search tests..." id="testSearch" />
                </div>
                <!-- Table -->
                <div class="table__wrap">
                    <table class="table">
                        <thead>
                            <tr>
                                <th class="table__header table__cell--id">Test ID <span class="table__sort">⇅</span></th>
                                <th class="table__header table__cell--msisdn">Test Name <span class="table__sort">⇅</span></th>
                                <th class="table__header table__cell--category">Category <span class="table__sort">⇅</span></th>
                                <th class="table__header table__cell--imsi">Questions <span class="table__sort">⇅</span></th>
                                <th class="table__header table__cell--date">Duration <span class="table__sort">⇅</span></th>
                                <th class="table__header table__cell--category">Status <span class="table__sort">⇅</span></th>
                                <th class="table__header table__cell--date">Created Date <span class="table__sort">⇅</span></th>
                                <th class="table__header table__cell--action">Actions</th>
                            </tr>
                            <tr class="table__filter-row">
                                <th>
                                    <div class="table__filter-wrap">
                                        <span class="table__filter-icon">🔍</span>
                                        <input class="table__filter-input" type="text" oninput="filterTable()" />
                                    </div>
                                </th>
                                <th>
                                    <div class="table__filter-wrap">
                                        <span class="table__filter-icon">🔍</span>
                                        <input class="table__filter-input" type="text" oninput="filterTable()" />
                                    </div>
                                </th>
                                <th>
                                    <div class="table__filter-wrap">
                                        <span class="table__filter-icon">🔍</span>
                                        <input class="table__filter-input" type="text" oninput="filterTable()" />
                                    </div>
                                </th>
                                <th>
                                    <div class="table__filter-wrap">
                                        <span class="table__filter-icon">🔍</span>
                                        <input class="table__filter-input" type="text" oninput="filterTable()" />
                                    </div>
                                </th>
                                <th>
                                    <div class="table__filter-wrap">
                                        <span class="table__filter-icon">🔍</span>
                                        <input class="table__filter-input" type="text" oninput="filterTable()" />
                                    </div>
                                </th>
                                <th>
                                    <div class="table__filter-wrap">
                                        <span class="table__filter-icon">🔍</span>
                                        <input class="table__filter-input" type="text" oninput="filterTable()" />
                                    </div>
                                </th>
                                <th>
                                    <div class="table__date-wrap">
                                        <span class="table__filter-icon">📅</span>
                                        <input class="table__date-input" type="date" oninput="filterTable()" />
                                    </div>
                                </th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="tableBody">
                            <tr class="table__empty-row">
                                <td colspan="8">No tests to display.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            `,
            users: '<div class="page-header">USERS</div><p>Users management coming soon...</p>',
            questions: '<div class="page-header">QUESTIONS</div><p>Questions management coming soon...</p>',
            reports: '<div class="page-header">REPORTS</div><p>Reports section coming soon...</p>',
            settings: '<div class="page-header">SETTINGS</div><p>Settings coming soon...</p>'
        };

        // Load page content dynamically
        function loadPage(page) {
            const content = document.getElementById('mainContent');
            content.innerHTML = pageTemplates[page] || '<div class="page-header">PAGE NOT FOUND</div>';
            
            // Update sidebar active state
            document.querySelectorAll('.sidebar__item').forEach(item => {
                item.classList.remove('sidebar__item--active');
            });
            event.target.closest('.sidebar__item').classList.add('sidebar__item--active');
            
            // Initialize page-specific functionality
            initializePage(page);
        }

        // Initialize page-specific functionality
        function initializePage(page) {
            if (page === 'dashboard') {
                loadDashboardData();
            } else if (page === 'tests') {
                loadExams();
                setupTestSearch();
            }
        }

        // Load dashboard data
        async function loadDashboardData() {
            try {
                const examsResponse = await fetch('/exams');
                const exams = await examsResponse.json();
                
                document.getElementById('totalExams').textContent = exams.length;
                document.getElementById('activeExams').textContent = exams.filter(e => e.isActive).length;
                
                const recentExamsTable = document.getElementById('recentExamsTable');
                if (exams.length === 0) {
                    recentExamsTable.innerHTML = '<tr class="table__empty-row"><td colspan="5">No exams found.</td></tr>';
                } else {
                    recentExamsTable.innerHTML = exams.slice(0, 5).map(exam => `
                        <tr>
                            <td>${exam.title}</td>
                            <td>${exam.questions ? exam.questions.length : 0}</td>
                            <td>${exam.duration} min</td>
                            <td><span class="status-badge status-${exam.isActive ? 'active' : 'inactive'}">${exam.isActive ? 'Active' : 'Inactive'}</span></td>
                            <td>${new Date(exam.createdAt).toLocaleDateString()}</td>
                        </tr>
                    `).join('');
                }
            } catch (error) {
                console.error('Error loading dashboard data:', error);
                document.getElementById('recentExamsTable').innerHTML = '<tr class="table__empty-row"><td colspan="5">Error loading data.</td></tr>';
            }
        }

        // Load exams data
        let allData = [];
        let filteredData = [];

        async function loadExams() {
            try {
                const response = await fetch('/exams');
                const exams = await response.json();
                
                allData = exams.map(exam => ({
                    id: exam._id,
                    name: exam.title,
                    category: exam.description || 'General',
                    questions: exam.questions ? exam.questions.length : 0,
                    duration: `${exam.duration} min`,
                    status: exam.isActive ? 'Active' : 'Draft',
                    createdDate: new Date(exam.createdAt).toLocaleDateString()
                }));
                
                filteredData = [...allData];
                renderTable(filteredData);
            } catch (error) {
                console.error('Error loading exams:', error);
                document.getElementById('tableBody').innerHTML = '<tr class="table__empty-row"><td colspan="8">Error loading exams. Please try again.</td></tr>';
            }
        }

        const renderTable = (data) => {
            const tbody = document.getElementById('tableBody');
            if (data.length === 0) {
                tbody.innerHTML = `<tr class="table__empty-row"><td colspan="8">No tests to display.</td></tr>`;
                return;
            }
            tbody.innerHTML = data.map(row => `
                <tr>
                    <td>${row.id}</td>
                    <td>${row.name}</td>
                    <td>${row.category}</td>
                    <td>${row.questions}</td>
                    <td>${row.duration}</td>
                    <td><span class="status-badge status-${row.status.toLowerCase()}">${row.status}</span></td>
                    <td>${row.createdDate}</td>
                    <td>
                        <button class="action-btn" onclick="editTest('${row.id}')" title="Edit">✏️</button>
                        <button class="action-btn" onclick="deleteTest('${row.id}')" title="Delete">🗑️</button>
                    </td>
                </tr>
            `).join('');
        };

        const filterTable = () => {
            const filters = Array.from(document.querySelectorAll('.table__filter-input, .table__date-input'))
                .map(i => i.value.toLowerCase().trim());

            filteredData = allData.filter(row => {
                const vals = [row.id, row.name, row.category, row.questions.toString(), row.duration, row.status, row.createdDate, ''];
                return vals.every((v, i) => !filters[i] || v.toLowerCase().includes(filters[i]));
            });

            renderTable(filteredData);
        };

        const testSearch = () => {
            const searchTerm = document.getElementById('testSearch').value.trim();
            if (!searchTerm) {
                renderTable(allData);
                return;
            }
            const result = allData.filter(r => 
                r.name.toLowerCase().includes(searchTerm.toLowerCase()) ||
                r.id.toLowerCase().includes(searchTerm.toLowerCase())
            );
            renderTable(result);
        };

        const setupTestSearch = () => {
            document.getElementById('testSearch').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') testSearch();
            });
        };

        const createNewTest = () => {
            const examName = prompt('Enter exam name:');
            if (examName) {
                createExam(examName);
            }
        };

        async function createExam(title) {
            try {
                const response = await fetch('/exams', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        title: title,
                        description: 'General exam',
                        duration: 60,
                        questions: []
                    })
                });
                
                if (response.ok) {
                    alert('Exam created successfully!');
                    loadExams();
                } else {
                    const error = await response.json();
                    alert('Error creating exam: ' + error.message);
                }
            } catch (error) {
                console.error('Error creating exam:', error);
                alert('Error creating exam. Please try again.');
            }
        }

        const importQuestions = () => {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json,.csv';
            input.onchange = async (e) => {
                const file = e.target.files[0];
                if (file) {
                    alert('File import functionality will be implemented with file: ' + file.name);
                }
            };
            input.click();
        };

        const exportResults = () => {
            const csv = [
                ['Test ID', 'Test Name', 'Category', 'Questions', 'Duration', 'Status', 'Created Date'],
                ...filteredData.map(row => [row.id, row.name, row.category, row.questions, row.duration, row.status, row.createdDate])
            ].map(row => row.join(',')).join('\n');
            
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'exams_export.csv';
            a.click();
        };

        const editTest = async (testId) => {
            try {
                const response = await fetch(`/exams/${testId}`);
                const exam = await response.json();
                
                const newName = prompt('Enter new exam name:', exam.title);
                if (newName && newName !== exam.title) {
                    const updateResponse = await fetch(`/exams/${testId}`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ title: newName })
                    });
                    
                    if (updateResponse.ok) {
                        alert('Exam updated successfully!');
                        loadExams();
                    } else {
                        const error = await updateResponse.json();
                        alert('Error updating exam: ' + error.message);
                    }
                }
            } catch (error) {
                console.error('Error editing exam:', error);
                alert('Error editing exam. Please try again.');
            }
        };

        const deleteTest = async (testId) => {
            if (confirm(`Are you sure you want to delete test ${testId}?`)) {
                try {
                    const response = await fetch(`/exams/${testId}`, {
                        method: 'DELETE'
                    });
                    
                    if (response.ok) {
                        alert('Exam deleted successfully!');
                        loadExams();
                    } else {
                        const error = await response.json();
                        alert('Error deleting exam: ' + error.message);
                    }
                } catch (error) {
                    console.error('Error deleting exam:', error);
                    alert('Error deleting exam. Please try again.');
                }
            }
        };

        const viewResults = () => {
            window.location.href = '/results';
        };

        const manageUsers = () => {
            alert('User management will be implemented');
        };

        const handleLogout = () => {
            if (confirm('Are you sure you want to logout?')) {
                window.location.href = '/auth/logout';
            }
        };

        // Load user info
        async function loadUserInfo() {
            try {
                const userResponse = await fetch('/auth/me');
                if (userResponse.ok) {
                    const user = await userResponse.json();
                    document.getElementById('currentUser').textContent = user.name || user.email || 'Unknown User';
                    const userInfoElement = document.getElementById('userInfo');
                    if (userInfoElement) {
                        userInfoElement.textContent = user.name || user.email || 'Unknown User';
                    }
                }
            } catch (error) {
                console.error('Error loading user info:', error);
            }
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', () => {
            loadUserInfo();
            loadPage('dashboard'); // Load dashboard by default
        });
    </script>
</body>
</html>
